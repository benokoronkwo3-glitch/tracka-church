  function Card({title,value,color}){return<div style={{background:"#fff",border:`1px solid ${T.border}`,borderRadius:11,padding:16,borderLeft:`4px solid ${color}`}}><div style={{fontSize:12,color:"#374151",marginBottom:4}}>{title}</div><div style={{fontSize:20,fontWeight:800,color}}>{value}</div></div>;}
  function Form({fields,onSave,onCancel}){const[v,setV]=useState(Object.fromEntries(fields.map(f=>[f.key,f.default||""])));const F=(k,val)=>setV(p=>({...p,[k]:val}));return<div style={{background:"#fff",border:`1px solid ${T.border}`,borderRadius:11,padding:17,marginBottom:16}}><div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(185px,1fr))",gap:12,marginBottom:14}}>{fields.map(f=><div key={f.key}><label style={{display:"block",fontSize:10,fontWeight:700,color:T.primary,marginBottom:5,textTransform:"uppercase"}}>{f.label}</label>{f.type==="select"?<select style={S.inp} value={v[f.key]} onChange={e=>F(f.key,e.target.value)}>{(f.opts||[]).map(o=><option key={o}>{o}</option>)}</select>:<input style={S.inp} type={f.type||"text"} placeholder={f.ph||""} value={v[f.key]} onChange={e=>F(f.key,e.target.value)}/></div>)}</div><div style={{display:"flex",gap:10}}><button style={S.canc} onClick={onCancel}>Cancel</button><button style={S.save} onClick={()=>onSave(v)}>Save</button></div></div>;}

  const svcTypes=["Sunday Service","Wednesday Service","Friday Service","Special Service","Harvest","Thanksgiving","Other"];
  const ofTypes=["General Offering","Special Offering","Building Fund","Mission","Welfare","Other"];
  const expCats=["Staff Salary","Utilities","Rent","Maintenance","Generator/Fuel","Welfare","Ministry","Miscellaneous"];
  const depts=["Choir","Ushering","Children Ministry","Youth","Prayer","Media","Welfare","Executive"];
  const[addOff,setAddOff]=useState(false);
  const[addTi,setAddTi]=useState(false);
  const[addEx,setAddEx]=useState(false);
  const[addMb,setAddMb]=useState(false);
  const[addPr,setAddPr]=useState(false);
  const[addUsr,setAddUsr]=useState(false);
  const[addBr,setAddBr]=useState("");
  const[contribModal,setContribModal]=useState(null);
  const[contrib,setContrib]=useState("");

  return<div style={{display:"flex",height:"100vh",background:T.light,fontFamily:"'DM Sans','Segoe UI',sans-serif",overflow:"hidden"}}>
