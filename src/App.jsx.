  const totTi=fTi.reduce((s,r)=>s+ +r.amount,0);
  const totEx=fEx.reduce((s,r)=>s+ +r.amount,0);
  const doAdd=async(table,data,setter)=>{const row={client_id:CID,...data,id:gid()};const{error}=await db.post(table,row);if(error){t2("Error saving","error");return;}setter(p=>[row,...p]);t2("Saved");};
  const doDel=async(table,id,setter)=>{await db.del(table,id);setter(p=>p.filter(x=>x.id!==id));setConfirm(null);t2("Deleted","info");};
