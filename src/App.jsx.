  const S={inp:{width:"100%",background:T.light,border:`1px solid ${T.border}`,borderRadius:7,padding:"9px 10px",fontSize:13,outline:"none",boxSizing:"border-box",color:T.dark},btn:{background:T.logo,color:"#fff",border:"none",borderRadius:8,padding:"9px 15px",fontWeight:700,fontSize:13,cursor:"pointer"},gBtn:{background:T.light,border:`1px solid ${T.border}`,color:T.primary,borderRadius:8,padding:"9px 15px",fontWeight:700,fontSize:13,cursor:"pointer"},save:{background:T.logo,border:"none",borderRadius:7,color:"#fff",padding:"10px 20px",fontWeight:700,cursor:"pointer",fontSize:14},canc:{background:T.mid,border:"none",borderRadius:7,color:T.primary,padding:"10px 20px",fontWeight:700,cursor:"pointer"},th:{textAlign:"left",fontSize:10,fontWeight:700,color:T.primary,padding:"8px 10px",borderBottom:`1px solid ${T.border}`,textTransform:"uppercase",whiteSpace:"nowrap"},td:{padding:"10px",fontSize:13,borderBottom:`1px solid ${T.mid}`,verticalAlign:"middle"},chip:(bg,tc)=>({background:bg||T.mid,color:tc||T.primary,fontSize:11,fontWeight:700,padding:"3px 8px",borderRadius:99})};
  const Tag=({c,bg,tc})=><span style={S.chip(bg,tc)}>{c}</span>;
