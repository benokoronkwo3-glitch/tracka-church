          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}><div style={{fontWeight:800,fontSize:18,color:T.dark}}>Projects</div><button style={S.btn} onClick={()=>setAddPr(v=>!v)}>{addPr?"Cancel":"New Project"}</button></div>
          {addPr&&<Form fields={[{key:"name",label:"Project Name",ph:"e.g. Building Renovation"},{key:"description",label:"Description",ph:"Brief description"},{key:"target",label:"Target Amount (N)",type:"number"},{key:"deadline",label:"Target Date",type:"date"}]} onSave={v=>{if(!v.name){t2("Enter project name","error");return;}doAdd("church_projects",{...v,target:+v.target||0,raised:0,status:"Active",created_at:tod()},setProjects);setAddPr(false);}} onCancel={()=>setAddPr(false)}/>}
          {contribModal&&<div style={{position:"fixed",inset:0,background:"#00000060",display:"flex",alignItems:"center",justifyContent:"center",zIndex:100}} onClick={()=>setContribModal(null)}><div style={{background:"#fff",borderRadius:13,padding:24,maxWidth:380,width:"90%"}} onClick={e=>e.stopPropagation()}><div style={{fontWeight:800,color:T.dark,marginBottom:16}}>{contribModal.name}</div><div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:16}}>{[["Target",fmt(contribModal.target)],["Raised",fmt(contribModal.raised||0)],["Balance",fmt(+contribModal.target-(+contribModal.raised||0))]].map(([l,v])=><div key={l} style={{background:T.light,borderRadius:8,padding:10,textAlign:"center"}}><div style={{fontSize:10,color:T.primary}}>{l}</div><div style={{fontWeight:800,color:T.dark,fontSize:13}}>{v}</div></div>)}</div><label style={{display:"block",fontSize:11,fontWeight:700,color:T.primary,marginBottom:5,textTransform:"uppercase"}}>Add Contribution (N)</label><input style={{...S.inp,marginBottom:14}} type="number" value={contrib} onChange={e=>setContrib(e.target.value)} autoFocus/><div style={{display:"flex",gap:10}}><button style={S.canc} onClick={()=>setContribModal(null)}>Cancel</button><button style={S.save} onClick={async()=>{const a=+contrib;if(!a||a<=0){t2("Enter valid amount","error");return;}const nr=(+contribModal.raised||0)+a;const ns=nr>=+contribModal.target?"Completed":"Active";await db.patch("church_projects",contribModal.id,{raised:nr,status:ns});setProjects(p=>p.map(x=>x.id===contribModal.id?{...x,raised:nr,status:ns}:x));setContribModal(null);setContrib("");t2("Contribution added");}}>Add</button></div></div></div>}
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:16}}>{projects.map(pr=>{const pct=Math.min(100,Math.round((+(pr.raised||0)/+(pr.target||1))*100));return<div key={pr.id} style={{background:"#fff",border:`1px solid ${T.border}`,borderRadius:11,padding:16}}><div style={{display:"flex",justifyContent:"space-between",marginBottom:8}}><div><div style={{fontWeight:800,color:T.dark,fontSize:14}}>{pr.name}</div><div style={{fontSize:12,color:"#374151"}}>{pr.description}</div></div><Tag c={pr.status} bg={pr.status==="Completed"?T.mid:"#fef9c3"} tc={pr.status==="Completed"?T.primary:"#f59e0b"}/></div><div style={{background:T.mid,borderRadius:8,height:8,marginBottom:8}}><div style={{background:T.primary,borderRadius:8,height:8,width:pct+"%"}}/></div><div style={{display:"flex",justifyContent:"space-between",fontSize:12,marginBottom:12}}><span>Raised: <strong style={{color:"#16a34a"}}>{fmt(pr.raised||0)}</strong></span><span>{pct}% of {fmt(pr.target)}</span></div><button onClick={()=>{setContribModal(pr);setContrib("");}} style={{...S.btn,width:"100%",justifyContent:"center"}}>+ Add Contribution</button></div>;})}
          {projects.length===0&&<div style={{color:"#94a3b8",padding:32}}>No projects yet</div>}</div>
        </div>}

        {tab==="branches"&&<div>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}><div style={{fontWeight:800,fontSize:18,color:T.dark}}>Branches</div><div style={{display:"flex",gap:8}}><input style={{...S.inp,width:180}} placeholder="New branch name..." value={addBr} onChange={e=>setAddBr(e.target.value)}/><button style={S.btn} onClick={()=>{if(!addBr.trim()){t2("Enter branch name","error");return;}if(!branches.includes(addBr.trim())){setBranches(p=>[...p,addBr.trim()]);t2("Branch added");}setAddBr("");}}>Add</button></div></div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(240px,1fr))",gap:16}}>{branches.map(b=>{const bO=offerings.filter(o=>o.branch===b).reduce((s,r)=>s+ +r.amount,0);const bT=tithes.filter(t=>t.branch===b).reduce((s,r)=>s+ +r.amount,0);const bE=expenses.filter(e=>e.branch===b).reduce((s,r)=>s+ +r.amount,0);return<div key={b} style={{background:"#fff",border:`1px solid ${T.border}`,borderRadius:11,padding:14}}><div style={{fontWeight:700,color:T.primary,marginBottom:10}}>{b}</div><div style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${T.mid}`,fontSize:13}}><span>Offerings</span><strong style={{color:"#16a34a"}}>{fmt(bO)}</strong></div><div style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${T.mid}`,fontSize:13}}><span>Tithes</span><strong style={{color:T.primary}}>{fmt(bT)}</strong></div><div style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${T.mid}`,fontSize:13}}><span>Expenses</span><strong style={{color:"#ef4444"}}>{fmt(bE)}</strong></div><div style={{display:"flex",justifyContent:"space-between",padding:"5px 0",fontSize:13}}><span>Balance</span><strong style={{color:bO+bT-bE>=0?"#16a34a":"#ef4444"}}>{fmt(bO+bT-bE)}</strong></div><button onClick={()=>{setBranch(b);setTab("dashboard");}} style={{...S.gBtn,width:"100%",marginTop:10,justifyContent:"center",fontSize:12}}>View Branch</button></div>;})}
          </div>
        </div>}

        {tab==="reports"&&<div>
          <div style={{fontWeight:800,fontSize:18,color:T.dark,marginBottom:16}}>Reports</div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(170px,1fr))",gap:12,marginBottom:16}}>
            <Card title="Offerings" value={fmt(totOf)} color="#16a34a"/>
            <Card title="Tithes" value={fmt(totTi)} color={T.primary}/>
            <Card title="Income" value={fmt(totOf+totTi)} color="#0369a1"/>
            <Card title="Expenses" value={fmt(totEx)} color="#ef4444"/>
            <Card title="Balance" value={fmt(totOf+totTi-totEx)} color={totOf+totTi-totEx>=0?"#16a34a":"#ef4444"}/>
            <Card title="Members" value={fMb.length} color={T.primary}/>
          </div>
          {isPastor&&<div style={{background:"#fff",border:`1px solid ${T.border}`,borderRadius:11,padding:14,marginBottom:16}}><div style={{fontWeight:700,color:T.primary,marginBottom:12,fontSize:11,textTransform:"uppercase"}}>Branch Performance</div><Tbl cols={["Branch","Offerings","Tithes","Expenses","Balance"]} rows={branches.map(b=>{const bO=offerings.filter(o=>o.branch===b).reduce((s,r)=>s+ +r.amount,0);const bT=tithes.filter(t=>t.branch===b).reduce((s,r)=>s+ +r.amount,0);const bE=expenses.filter(e=>e.branch===b).reduce((s,r)=>s+ +r.amount,0);return[b,<span style={{color:"#16a34a"}}>{fmt(bO)}</span>,<span style={{color:T.primary}}>{fmt(bT)}</span>,<span style={{color:"#ef4444"}}>{fmt(bE)}</span>,<strong style={{color:bO+bT-bE>=0?"#16a34a":"#ef4444"}}>{fmt(bO+bT-bE)}</strong>];})}/>
          </div>}
        </div>}

        {tab==="users"&&isPastor&&<div>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}><div style={{fontWeight:800,fontSize:18,color:T.dark}}>Users and Access</div><button style={S.btn} onClick={()=>setAddUsr(v=>!v)}>{addUsr?"Cancel":"Add User"}</button></div>
          {addUsr&&<Form fields={[{key:"name",label:"Full Name",ph:"e.g. Bro Emeka"},{key:"email",label:"Email",ph:"emeka@church.ng"},{key:"pin",label:"PIN",ph:"4-8 digits"},{key:"role",label:"Role",type:"select",opts:["worker","secretary","treasurer"],default:"worker"},{key:"branch",label:"Branch",type:"select",opts:branches,default:branches[0]}]} onSave={async v=>{if(!v.name||!v.email||!v.pin){t2("Fill all fields","error");return;}const row={client_id:CID,...v,id:gid(),active:true};const{error}=await db.post("users",row);if(error){t2("Error","error");return;}setUsers(p=>[...p,row]);t2(v.name+" added");setAddUsr(false);}} onCancel={()=>setAddUsr(false)}/>}
          <Tbl cols={["Name","Email","Role","Branch","PIN","Status"]} rows={users.map(u=>[<strong style={{color:T.dark}}>{u.name}</strong>,u.email,<Tag c={u.role} bg={T.mid} tc={T.primary}/>,u.branch||"All",<code style={{background:T.mid,padding:"2px 6px",borderRadius:4,color:T.primary,fontSize:12}}>{u.pin}</code>,<Tag c={u.active?"Active":"Disabled"} bg={u.active?T.mid:"#fef2f2"} tc={u.active?T.primary:"#ef4444"}/>])}/>
        </div>}

      </div>
    </main>
    {toast&&<div style={{position:"fixed",bottom:18,right:18,color:"#fff",padding:"10px 16px",borderRadius:9,fontWeight:700,fontSize:13,zIndex:300,boxShadow:"0 8px 24px #0009",background:toast.type==="error"?"#dc2626":toast.type==="info"?"#2563eb":"#16a34a"}}>{toast.msg}</div>}
    {confirm&&<div style={{position:"fixed",inset:0,background:"#00000060",display:"flex",alignItems:"center",justifyContent:"center",zIndex:100}} onClick={()=>setConfirm(null)}><div style={{background:"#fff",borderRadius:13,padding:24,maxWidth:350,width:"90%"}} onClick={e=>e.stopPropagation()}><div style={{fontWeight:700,fontSize:15,marginBottom:18,color:T.dark}}>{confirm.msg}</div><div style={{display:"flex",gap:10}}><button style={S.canc} onClick={()=>setConfirm(null)}>Cancel</button><button style={{...S.save,background:"#dc2626"}} onClick={confirm.fn}>Yes Delete</button></div></div></div>}
  </div>;
}
