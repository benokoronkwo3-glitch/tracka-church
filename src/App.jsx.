          {addTi&&<Form fields={[{key:"date",label:"Date",type:"date",default:tod()},{key:"member_name",label:"Member Name",ph:"Anonymous"},{key:"amount",label:"Amount (N)",type:"number"},{key:"period",label:"Period",ph:"e.g. January 2025"},{key:"branch",label:"Branch",type:"select",opts:branches,default:branches[0]}]} onSave={v=>{if(!v.amount){t2("Enter amount","error");return;}doAdd("church_tithes",{...v,amount:+v.amount,recorded_by:user.id},setTithes);setAddTi(false);}} onCancel={()=>setAddTi(false)}/>}
