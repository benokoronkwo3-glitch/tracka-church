          {addOff&&<Form fields={[{key:"date",label:"Date",type:"date",default:tod()},{key:"service_type",label:"Service Type",type:"select",opts:svcTypes,default:svcTypes[0]},{key:"offering_type",label:"Offering Type",type:"select",opts:ofTypes,default:ofTypes[0]},{key:"amount",label:"Amount (N)",type:"number"},{key:"branch",label:"Branch",type:"select",opts:branches,default:branches[0]}]} onSave={v=>{if(!v.amount){t2("Enter amount","error");return;}doAdd("church_offerings",{...v,amount:+v.amount,recorded_by:user.id},setOfferings);setAddOff(false);}} onCancel={()=>setAddOff(false)}/>}
          <Tbl cols={["Date","Service","Type","Amount","Branch"]} rows={fOf.map(o=>[o.date,<Tag c={o.service_type} bg={T.mid} tc={T.primary}/>,o.offering_type,<strong style={{color:"#16a34a"}}>{fmt(o.amount)}</strong>,o.branch])}/>
        </div>}

        {tab==="tithes"&&<div>
